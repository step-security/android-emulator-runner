{
  "name": "android-emulator-runner",
  "version": "2.37.0",
  "private": true,
  "description": "A GitHub Action for installing, configuring and running Android Emulators on hardware-accelerated runners.",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/main.ts -o dist --source-map --license licenses.txt",
    "test": "tsc --noEmit && jest",
    "lint": "eslint . --ext .ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/step-security/android-emulator-runner.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "engines": {
    "node": ">=24"
  },
  "author": "step-security",
  "license": "Apache 2.0",
  "dependencies": {
    "@actions/core": "^2.0.0",
    "@actions/exec": "^2.0.0",
    "@actions/tool-cache": "^3.0.0",
    "axios": "^1.16.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^24.1.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vercel/ncc": "^0.38.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "jest-circus": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.5",
    "typescript": "^5.5.4"
  }
}
